# ═══════════════════════════════════════════════════════════════════════════
# Socle V2 — production environment variables
# Copy this list into Vercel → Project Settings → Environment Variables.
# All values marked REQUIRED must be set before deployment works.
# ═══════════════════════════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://mkgkrfcfhtrlecfuzroz.supabase.co   # REQUIRED
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key from Supabase dashboard>      # REQUIRED
SUPABASE_SERVICE_ROLE_KEY=<service role key — never expose client-side> # REQUIRED

# ── Telegram ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=<from @BotFather>                    # REQUIRED for alerts
TELEGRAM_ANTHONY_CHAT_ID=<your numeric chat ID>         # REQUIRED for alerts
# How to get TELEGRAM_ANTHONY_CHAT_ID:
#   1. Send /start to your bot in Telegram
#   2. Hit GET https://<your-vercel-url>/api/telegram/identify (logged in as admin)
#   3. Copy the id field

TELEGRAM_WEBHOOK_SECRET=<openssl rand -hex 32>          # REQUIRED for inbound cmds
# After deploy, register webhook:
#   curl -X POST https://<vercel-url>/api/telegram/setup \
#        -H "Content-Type: application/json" \
#        -d '{"publicUrl":"https://<vercel-url>"}'

# ── n8n integration ──────────────────────────────────────────────────────
N8N_SHARED_KEY=<same value used in n8n credential store>  # REQUIRED
# After deploy, update n8n workflow 2gZp3dbXCZPU3NV6:
#   Change https://legislate-onyx-crane.ngrok-free.dev → https://<vercel-url>
#   in Notify CRM - Lead, Log Event - Triage A, Log Event - Triage B nodes.

N8N_ENRICHMENT_WEBHOOK_URL=                             # optional — leave blank until W5 built
