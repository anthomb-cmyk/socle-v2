# Copy to .env.local in /web and fill in. NEVER commit the filled file.

# ─── Supabase ─────────────────────────────────────────────────────────
# Project URL — from Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Anon (public) key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-only, NEVER ship to client.
# Used by /scripts/migrate-v1-to-v2.ts and n8n
SUPABASE_SERVICE_ROLE_KEY=

# ─── n8n ──────────────────────────────────────────────────────────────
# Public webhook base URL for the rôle-import workflow
N8N_ROLE_IMPORT_WEBHOOK=https://your-n8n.example.com/webhook/role-import
# Public webhook base URL for the enrichment workflow
N8N_ENRICHMENT_WEBHOOK=https://your-n8n.example.com/webhook/enrich-lead

# ─── Twilio ───────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1...

# ─── Phone enrichment APIs (used by n8n) ──────────────────────────────
BRAVE_SEARCH_API_KEY=
GOOGLE_PLACES_API_KEY=
B2BHINT_API_KEY=

# ─── OpenAI (planner / matricule classification) ──────────────────────
OPENAI_API_KEY=

# ─── Email (Resend) ───────────────────────────────────────────────────
RESEND_API_KEY=

# ─── Google Calendar (per-user OAuth, set via UI not env) ─────────────
# Client ID/secret used to issue per-user tokens
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ─── Local dev only ───────────────────────────────────────────────────
# Set NEXT_PUBLIC_DEV_USER to bypass auth in local dev (NEVER in prod)
NEXT_PUBLIC_DEV_USER=
